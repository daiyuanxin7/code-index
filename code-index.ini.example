# code-index 配置示例
# ─────────────────────────────────────────────────────────────
# 用法：复制本文件为 code-index.ini 并填写真实连接信息。
#   cp code-index.ini.example code-index.ini
#
# 所有段都是【可选】的：不写任何配置，--build 即按内置默认约定工作
# （Spring Boot + MyBatis + RuoYi/JeecgBoot-Vue）。
# 下面的 [scan]/[java]/[mapper]/[vue] 用于「配置驱动适配」——当你的项目
# 用了不同目录结构 / 命名约定 / 注解时，覆盖对应项即可，无需改工具源码。
# 运行 `python3 code_index.py --doctor` 可查看当前生效的全部约定。
#
# ⚠️ code-index.ini 若含数据库密码，已在 .gitignore 中忽略，切勿提交到版本库。
#    也可改用环境变量 CODE_INDEX_DB_* 或命令行 --host/--db/--user/--password。

# ─────────────────────────────────────────────────────────────
# 配置驱动适配：覆盖默认约定（全部可选，值为内置默认）
# ─────────────────────────────────────────────────────────────
# [scan]
# # 额外忽略的目录（并入内置忽略表 node_modules/target/... 之外），逗号分隔
# ignore_dirs = generated, third_party
#
# [java]
# source_marker = src/main/java                 # 后端源码根标志（相对各模块）
# source_suffixes = .java                        # 方法索引扫描的源文件后缀
# controller_suffixes = Controller.java          # API 索引的 Controller 文件后缀，可多个：Controller.java, Api.java
# class_mapping_annotation = RequestMapping      # 类级路径前缀注解
# # HTTP 映射注解 → 方法，形如 注解:方法，逗号分隔
# mapping_annotations = GetMapping:GET, PostMapping:POST, PutMapping:PUT, DeleteMapping:DELETE, PatchMapping:PATCH, RequestMapping:ANY
#
# [mapper]
# java_suffixes = Mapper.java                    # Mapper 接口文件后缀，可多个：Mapper.java, Dao.java
# xml_marker = src/main/resources/mapper         # Mapper XML 根标志
# xml_suffixes = .xml
# sql_tags = select, insert, update, delete      # XML 里的 SQL 标签
# inline_sql_annotations = Select, Insert, Update, Delete   # 内联 SQL 注解
#
# [vue]
# root_markers = src/views, src/router           # 前端根标志目录（任一存在即为前端根）
# router_dir = src/router                         # 自动扫描的静态路由目录
# views_alias = @/views                           # 视图组件别名前缀（path→文件 映射用）

[vue_route_db]
host = 127.0.0.1
port = 3306
database = your-database
user = your-user
password = your-password
# 菜单表名，RuoYi 默认 sys_menu
table = sys_menu

# ─────────────────────────────────────────────────────────────
# 前端静态路由：手动指定路由文件（可选）
# 当路由不在 src/router 自动扫描范围内时使用，例如 JeecgBoot 把路由表
# 写在 src/config/router.config.js。多个文件用逗号或换行分隔。
# 路径相对 Vue 前端根（与 @/views 一致）或绝对路径。
# 也可用命令行 --route-file，或环境变量 CODE_INDEX_ROUTE_FILES（逗号分隔）。
[vue_route_static]
files = src/config/router.config.js
